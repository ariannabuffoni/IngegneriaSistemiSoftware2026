//		whenMsg luce -> handleLuce
//		
//	State handleLuce {
//		printCurrentMessage color magenta
//	}
//	
//	Transition t0 
//		whenMsg luce -> handleLuce
//}

QActor griddisplaymock context ctxfirefly {
	State s0 initial {
		printCurrentMessage color magenta
		println("$name | starts") color magenta
	}
	
	Transition t0 
		whenMsg cellstate -> display
		
	State display {
		printCurrentMessage color magenta
	}
	
	Transition t0 
		whenMsg cellstate -> display
	
}